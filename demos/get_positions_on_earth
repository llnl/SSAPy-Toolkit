import ssapy
import numpy as np
from astropy.time import Time
import matplotlib.pyplot as plt

# Define time for consistency
t = Time("2025-1-1")

# Generate latitude and longitude grids (every 15 degrees)
latitudes = np.arange(-90, 91, 15)  # -90 to 90 inclusive
longitudes = np.arange(-180, 181, 15)  # -180 to 180 inclusive

# Initialize arrays to store position coordinates
x_coords = []
y_coords = []
z_coords = []

# Compute position for each lat/lon pair
for lat in latitudes:
    for lon in longitudes:
        observer = ssapy.EarthObserver(lon=lon, lat=lat, fast=False)
        r, _ = observer.getRV(t)  # Ignore velocity
        x_coords.append(r[0])  # ITRF x-coordinate (meters)
        y_coords.append(r[1])  # ITRF y-coordinate (meters)
        z_coords.append(r[2])  # ITRF z-coordinate (meters)

# Convert to kilometers for plotting
x_coords = np.array(x_coords) / 1000
y_coords = np.array(y_coords) / 1000
z_coords = np.array(z_coords) / 1000

# Create a 3D plot
fig = plt.figure(figsize=(10, 8))
ax = fig.add_subplot(111, projection='3d')

# Plot Earth as a wireframe sphere (approximate radius)
R_earth = ssapy.constants.EARTH_RADIUS / 1e3
u = np.linspace(0, 2 * np.pi, 100)
v = np.linspace(0, np.pi, 100)
x_earth = R_earth * np.outer(np.cos(u), np.sin(v))
y_earth = R_earth * np.outer(np.sin(u), np.sin(v))
z_earth = R_earth * np.outer(np.ones(np.size(u)), np.cos(v))
ax.plot_wireframe(x_earth, y_earth, z_earth, color='blue', alpha=0.2, label='Earth')

# Plot observer positions
ax.scatter(x_coords, y_coords, z_coords, c='red', s=50, label='Observer Positions')

# Set labels and title
ax.set_xlabel('X (km)')
ax.set_ylabel('Y (km)')
ax.set_zlabel('Z (km)')
ax.set_title('EarthObserver Positions at 15° Lat/Lon Intervals')
ax.legend()

# Equal aspect ratio
ax.set_box_aspect([1, 1, 1])

# Show plot
plt.show()
