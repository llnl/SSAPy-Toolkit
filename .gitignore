##########################
# SSAPy-specific ignores #
##########################

*.h5
**/*.h5

# Local data products and generated analysis/demo outputs belong outside this
# source repository. Persist reusable data in SSAPy-Data instead.
data/
outputs/
demo_gallery_output/
site/

# Generated media and bulky artifacts should be created by demos/docs workflows,
# not committed to the repository.
*.png
*.jpg
*.jpeg
*.gif
*.svg
*.pdf
*.mp4
*.mov
*.avi
*.webm
*.heic
*.npy
*.npz
*.fits
*.fit
*.csv
*.parquet
*.feather
*.dat
*.bin
*.egm
*.cof
*.bpc
*.sqlite
*.db
*.7z
*.zip
*.tar
*.tar.gz
*.tar.bz2
*.tar.xz
*.tgz
*.gz
*.bz2
*.xz
*.pkl
*.pickle

###########################
# Python-specific ignores #
###########################

# Byte-compiled / optimized / DLL files
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
dist/
develop-eggs/
downloads/
wheels/
site/

# Python egg metadata
*.egg-info/
**/*.egg-info/
*.egg
**/*.egg
.eggs/
eggs/

# Virtual environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache/
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
pytest.xml
pytest_session.txt
cover/

# Type checker / linter caches
.mypy_cache/
.ruff_cache/
.pyre/

# Sphinx documentation
docs/_build/
docs/generated/

# Jupyter Notebook
.ipynb_checkpoints/
**/.ipynb_checkpoints/
**/*-checkpoint.ipynb

##################################
# Visual Studio Code / IDE files #
##################################

.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace
.history/

##########################
# OS-specific ignores    #
##########################

.DS_Store
*~docs/generated/
